---
import Layout from '../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://fraisdenotaire-calcul.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Glossaire", "item": "https://fraisdenotaire-calcul.fr/glossaire/" }
  ]
};

const terms = [
  {
    term: "Acte authentique",
    definition: "L'acte authentique est le document officiel redige et signe par le notaire lors de la vente d'un bien immobilier. Il confere a la transaction une force probante et une force executoire. C'est l'acte definitif qui transfere la propriete du vendeur a l'acheteur."
  },
  {
    term: "Ancien (bien immobilier)",
    definition: "Un bien immobilier est considere comme ancien des lors qu'il a deja fait l'objet d'une premiere mutation, c'est-a-dire qu'il a deja ete vendu au moins une fois. Les frais de notaire dans l'ancien sont plus eleves que dans le neuf, en raison de droits de mutation superieurs."
  },
  {
    term: "Compromis de vente",
    definition: "Le compromis de vente (ou promesse synallagmatique de vente) est un avant-contrat par lequel le vendeur et l'acheteur s'engagent mutuellement a conclure la vente a un prix determine. Il precede la signature de l'acte authentique et peut etre signe sous seing prive ou devant notaire."
  },
  {
    term: "Contribution de securite immobiliere",
    definition: "La contribution de securite immobiliere (anciennement salaire du conservateur des hypotheques) est une taxe perçue par l'Etat lors de la publication d'un acte de vente au service de la publicite fonciere. Son taux est de 0,10 % du prix du bien, avec un minimum de 15 euros."
  },
  {
    term: "Debours",
    definition: "Les debours sont les sommes avancees par le notaire pour le compte de son client afin de couvrir les frais lies aux formalites administratives : extraits cadastraux, etats hypothecaires, timbres fiscaux et frais de publication. Ils sont refactures a l'euro pres."
  },
  {
    term: "DMTO (Droits de Mutation a Titre Onereux)",
    definition: "Les DMTO sont les taxes percues par le departement et la commune lors de la vente d'un bien immobilier. Ils constituent la part la plus importante des frais de notaire dans l'ancien. Le taux normal est de 5,80 % dans la plupart des departements (5,09 % dans quelques exceptions)."
  },
  {
    term: "Droits de mutation",
    definition: "Les droits de mutation sont les taxes percues par l'Etat et les collectivites territoriales lors du transfert de propriete d'un bien immobilier. Ils comprennent la taxe departementale, la taxe communale et les frais d'assiette. Leur montant varie selon que le bien est neuf ou ancien."
  },
  {
    term: "Emoluments du notaire",
    definition: "Les emoluments sont la remuneration du notaire pour les actes qu'il instrumente. Ils sont reglementes par l'Etat et calcules selon un bareme proportionnel au prix de vente, avec des tranches degressives. Tous les notaires appliquent le meme bareme. Une remise de 20 % est possible sur la tranche superieure a 100 000 euros."
  },
  {
    term: "Frais de formalites",
    definition: "Les frais de formalites correspondent aux couts des demarches administratives effectuees par le notaire : demandes de pieces d'urbanisme, copies d'actes, frais de publication et d'enregistrement. Ils font partie des debours et sont factures au cout reel."
  },
  {
    term: "Honoraires de negociation",
    definition: "Les honoraires de negociation sont une remuneration versee au notaire lorsqu'il intervient comme intermediaire dans la mise en relation entre le vendeur et l'acheteur. Contrairement aux emoluments, ces honoraires sont libres et negociables. Ils ne s'appliquent que si le notaire a joue un role d'entremise."
  },
  {
    term: "Hypotheque",
    definition: "L'hypotheque est une garantie reelle prise par la banque sur un bien immobilier pour securiser un pret. L'inscription hypothecaire engendre des frais notaries supplementaires (taxe de publicite fonciere, contribution de securite immobiliere) qui s'ajoutent aux frais d'acquisition."
  },
  {
    term: "Neuf (bien immobilier)",
    definition: "Un bien immobilier est considere comme neuf s'il n'a jamais ete habite ou s'il est achete en VEFA (Vente en l'Etat Futur d'Achevement). Les frais de notaire dans le neuf sont reduits (2 a 3 % du prix) car les droits de mutation sont remplaces par la TVA immobiliere deja incluse dans le prix."
  },
  {
    term: "Prorata de taxes",
    definition: "Le prorata de taxes correspond au remboursement par l'acheteur au vendeur de la part de taxe fonciere couvrant la periode allant de la date de vente au 31 decembre de l'annee en cours. Ce calcul est effectue au jour pres et figure dans l'acte authentique."
  },
  {
    term: "SCI (Societe Civile Immobiliere)",
    definition: "La SCI est une structure juridique permettant a plusieurs personnes de detenir et gerer un patrimoine immobilier en commun. L'acquisition d'un bien via une SCI peut engendrer des frais de notaire specifiques, notamment pour la redaction des statuts et les formalites de publication."
  },
  {
    term: "Taxe de publicite fonciere",
    definition: "La taxe de publicite fonciere est un impot percu par l'Etat lors de la publication d'un acte de vente au service de la publicite fonciere. Dans la plupart des departements, elle est integree aux droits de mutation. Son taux varie selon la nature de l'acte."
  },
  {
    term: "Viager",
    definition: "Le viager est un mode de vente immobiliere dans lequel l'acheteur verse un bouquet (somme initiale) puis une rente viagere au vendeur jusqu'a son deces. Les frais de notaire en viager sont calcules sur la valeur en capital de la rente et du bouquet, selon un bareme specifique."
  }
];
---
<Layout title="Glossaire des frais de notaire - Frais de Notaire Calcul" description="Definitions des termes cles des frais de notaire : emoluments, droits de mutation, DMTO, debours, acte authentique et plus encore.">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-8">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-gray-700">Accueil</a></li>
        <li>/</li>
        <li class="text-gray-800 font-medium">Glossaire</li>
      </ol>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">Glossaire des frais de notaire</h1>
    <p class="text-gray-600 mb-8">Retrouvez les definitions des termes essentiels lies aux frais de notaire et aux transactions immobilieres en France. Ce glossaire vous aide a comprendre chaque composante de vos frais d'acquisition.</p>

    <div class="space-y-6">
      {terms.map((item) => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-indigo-700 mb-2">{item.term}</h2>
          <p class="text-gray-600">{item.definition}</p>
        </div>
      ))}
    </div>
  </div>
</Layout>
