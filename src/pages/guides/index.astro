---
import Layout from '../../layouts/Layout.astro';

const guides = [
  {
    title: "Frais de notaire : ancien vs neuf",
    description: "Comprenez pourquoi les frais de notaire diffèrent entre l'immobilier ancien et neuf. Exemples chiffrés et explications détaillées des droits de mutation.",
    href: "/guides/frais-notaire-ancien-vs-neuf/",
    icon: "🏠",
    tag: "Immobilier"
  },
  {
    title: "Droits de succession en ligne directe",
    description: "Tout savoir sur les droits de succession entre parents et enfants : abattements, barème progressif, exemples concrets de calcul.",
    href: "/guides/droits-succession-ligne-directe/",
    icon: "👨‍👩‍👧‍👦",
    tag: "Succession"
  },
  {
    title: "Donation entre vifs : guide complet",
    description: "Abattements, rappel fiscal des 15 ans, stratégies d'optimisation. Tout ce qu'il faut savoir pour transmettre de son vivant.",
    href: "/guides/donation-entre-vifs/",
    icon: "🎁",
    tag: "Donation"
  },
  {
    title: "Comment réduire ses frais de notaire",
    description: "Astuces légales pour diminuer vos frais d'acquisition : déduction du mobilier, négociation des émoluments, choix du timing.",
    href: "/guides/reduire-frais-notaire/",
    icon: "💰",
    tag: "Immobilier"
  },
  {
    title: "Frais de notaire pour un terrain",
    description: "Spécificités des frais de notaire lors de l'achat d'un terrain à bâtir ou agricole. Impact sur le projet de construction.",
    href: "/guides/frais-notaire-terrain/",
    icon: "🌍",
    tag: "Immobilier"
  },
  {
    title: "Succession du conjoint survivant",
    description: "Droits du conjoint survivant, exonération TEPA, options entre usufruit et pleine propriété. Guide complet.",
    href: "/guides/succession-conjoint/",
    icon: "💍",
    tag: "Succession"
  },
  {
    title: "Émoluments du notaire : comprendre le barème",
    description: "Décryptage complet de la facture du notaire : émoluments proportionnels, taxes, débours et contributions diverses.",
    href: "/guides/emoluments-notaire-bareme/",
    icon: "📊",
    tag: "Notaire"
  },
  {
    title: "Assurance-vie et succession",
    description: "Régime fiscal spécial de l'assurance-vie, abattement de 152 500 €, clauses bénéficiaires. Optimisez la transmission.",
    href: "/guides/succession-assurance-vie/",
    icon: "🛡️",
    tag: "Succession"
  },
  {
    title: "Guide complet de la succession",
    description: "De l'ouverture de la succession au partage des biens : délais, formalités, rôle du notaire et coûts à prévoir.",
    href: "/guide-succession/",
    icon: "📋",
    tag: "Succession"
  },
  {
    title: "FAQ - Questions fréquentes",
    description: "Réponses aux questions les plus courantes sur les frais de notaire, les droits de succession et les donations.",
    href: "/faq/",
    icon: "❓",
    tag: "Général"
  }
];

const tagColors: Record<string, string> = {
  "Immobilier": "bg-primary-100 text-primary-700",
  "Succession": "bg-secondary-100 text-secondary-700",
  "Donation": "bg-accent-100 text-accent-700",
  "Notaire": "bg-primary-100 text-primary-700",
  "Général": "bg-gray-100 text-gray-700"
};
---

<Layout
  title="Guides pratiques - Frais de notaire, succession et donation"
  description="Guides complets et gratuits sur les frais de notaire, droits de succession, donations et stratégies d'optimisation fiscale en France."
>
  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-3">
      <nav aria-label="Fil d'Ariane" class="text-sm text-gray-500">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
          <li class="text-gray-300">/</li>
          <li class="text-gray-900 font-medium">Guides</li>
        </ol>
      </nav>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://fraisdenotaire-calcul.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://fraisdenotaire-calcul.fr/guides/" }
    ]
  })} />

  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Page header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-primary-800 mb-4">Guides pratiques</h1>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Retrouvez tous nos guides détaillés pour comprendre les frais de notaire, les droits de succession, les donations et les stratégies d'optimisation. Contenus mis à jour avec les barèmes en vigueur.
      </p>
    </div>

    <!-- Guides grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {guides.map((guide) => (
        <a
          href={guide.href}
          class="group bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-primary-300 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-start justify-between mb-3">
            <span class="text-3xl" role="img" aria-hidden="true">{guide.icon}</span>
            <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${tagColors[guide.tag] || 'bg-gray-100 text-gray-700'}`}>
              {guide.tag}
            </span>
          </div>
          <h2 class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">
            {guide.title}
          </h2>
          <p class="text-sm text-gray-600 leading-relaxed flex-1">
            {guide.description}
          </p>
          <div class="mt-4 text-sm font-medium text-primary-600 group-hover:text-primary-700 flex items-center gap-1">
            Lire le guide
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA section -->
    <div class="mt-16 bg-primary-600 rounded-2xl p-8 md:p-12 text-center text-white">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Estimez vos frais de notaire gratuitement</h2>
      <p class="text-primary-100 mb-6 max-w-2xl mx-auto">
        Utilisez notre simulateur en ligne pour calculer vos frais de notaire en quelques clics. Résultat immédiat, barèmes à jour.
      </p>
      <a href="/" class="inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-primary-900 font-bold px-8 py-3 rounded-lg transition-colors">
        Lancer le simulateur
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</Layout>
