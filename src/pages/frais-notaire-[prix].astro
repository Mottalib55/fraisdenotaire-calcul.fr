---
import Layout from '../layouts/Layout.astro';
import { prixData, getAdjacentPrices, type PrixDataEntry } from '../lib/prix-data.js';

export function getStaticPaths() {
  return prixData.map((entry) => ({
    params: { prix: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: PrixDataEntry;
}

const { entry } = Astro.props;
const { price, slug, label, ancien, neuf } = entry;
const { prev, next } = getAdjacentPrices(slug);

function formatEuro(n: number): string {
  return new Intl.NumberFormat('fr-FR', {
    style: 'currency',
    currency: 'EUR',
    minimumFractionDigits: 0,
    maximumFractionDigits: 2,
  }).format(n);
}

function formatPercent(n: number): string {
  return n.toFixed(2).replace('.', ',') + ' %';
}

// Dynamic content variations based on price
const priceNum = price;
const isLowBudget = priceNum <= 200_000;
const isMidBudget = priceNum > 200_000 && priceNum <= 400_000;
const isHighBudget = priceNum > 400_000 && priceNum <= 750_000;
const isLuxury = priceNum > 750_000;

const economieNeuf = formatEuro(ancien.totalFrais - neuf.totalFrais);
const budgetTotal = formatEuro(priceNum + ancien.totalFrais);
const budgetTotalNeuf = formatEuro(priceNum + neuf.totalFrais);

const pageTitle = `Frais de notaire pour ${label} - Calcul 2026`;
const pageDesc = `Frais de notaire pour un achat immobilier à ${label} : ${formatEuro(ancien.totalFrais)} dans l'ancien (${formatPercent(ancien.pourcentageEffectif)}) ou ${formatEuro(neuf.totalFrais)} dans le neuf (${formatPercent(neuf.pourcentageEffectif)}). Calcul détaillé 2026.`;

// FAQ data
const faqData = [
  {
    question: `Quels sont les frais de notaire pour un bien à ${label} dans l'ancien ?`,
    answer: `Pour un bien ancien à ${label}, les frais de notaire s'élèvent à ${formatEuro(ancien.totalFrais)}, soit ${formatPercent(ancien.pourcentageEffectif)} du prix d'achat. Ce montant comprend ${formatEuro(ancien.droitsMutation)} de droits de mutation, ${formatEuro(ancien.emolumentsTTC)} d'émoluments du notaire (TTC), ${formatEuro(ancien.securiteImmobiliere)} de contribution de sécurité immobilière et ${formatEuro(ancien.debours)} de débours.`,
  },
  {
    question: `Combien économise-t-on en frais de notaire en achetant un bien neuf à ${label} ?`,
    answer: `En achetant un bien neuf à ${label}, les frais de notaire ne sont que de ${formatEuro(neuf.totalFrais)} (${formatPercent(neuf.pourcentageEffectif)}) contre ${formatEuro(ancien.totalFrais)} dans l'ancien. L'économie est de ${economieNeuf}, principalement grâce à la réduction des droits de mutation (0,715 % au lieu de 5,81 %).`,
  },
  {
    question: `Quel budget total prévoir pour un achat immobilier à ${label} ?`,
    answer: `Pour un achat dans l'ancien à ${label}, le budget total (prix + frais de notaire) s'élève à ${budgetTotal}. Pour un bien neuf au même prix, le budget total est de ${budgetTotalNeuf}. Il faut également prévoir d'éventuels frais d'agence immobilière et frais de garantie bancaire.`,
  },
];
---

<Layout title={pageTitle} description={pageDesc}>
  <!-- Schema.org BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": "https://fraisdenotaire-calcul.fr/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": `Frais de notaire pour ${label}`,
        "item": `https://fraisdenotaire-calcul.fr/frais-notaire-${slug}/`
      }
    ]
  })} />

  <!-- Schema.org FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqData.map((faq) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer,
      },
    })),
  })} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-600 to-primary-700 text-white py-12">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <nav class="text-sm text-primary-200 mb-6">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <span class="mx-2">/</span>
        <span class="text-white">Frais de notaire pour {label}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Frais de notaire pour {label}
      </h1>
      <p class="text-lg text-primary-100 max-w-2xl mx-auto">
        Calcul détaillé des frais de notaire pour un achat immobilier à {label} - ancien et neuf comparés. Barèmes 2026.
      </p>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <!-- Summary cards -->
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-primary-600 text-white rounded-xl p-6 text-center">
        <p class="text-sm uppercase tracking-wide opacity-80">Ancien - Frais de notaire</p>
        <p class="text-4xl font-bold mt-2">{formatEuro(ancien.totalFrais)}</p>
        <p class="text-lg mt-1 opacity-90">soit {formatPercent(ancien.pourcentageEffectif)} du prix</p>
      </div>
      <div class="bg-secondary-500 text-white rounded-xl p-6 text-center">
        <p class="text-sm uppercase tracking-wide opacity-80">Neuf - Frais de notaire</p>
        <p class="text-4xl font-bold mt-2">{formatEuro(neuf.totalFrais)}</p>
        <p class="text-lg mt-1 opacity-90">soit {formatPercent(neuf.pourcentageEffectif)} du prix</p>
      </div>
    </div>

    <!-- Detailed comparison table -->
    <div class="overflow-x-auto mb-10">
      <table class="w-full border-collapse border border-gray-300 text-sm">
        <thead>
          <tr class="bg-primary-600 text-white">
            <th class="border border-primary-500 px-4 py-3 text-left">Composante</th>
            <th class="border border-primary-500 px-4 py-3 text-right">Ancien</th>
            <th class="border border-primary-500 px-4 py-3 text-right">Neuf</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="border border-gray-300 px-4 py-3">Prix du bien</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(price)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(price)}</td>
          </tr>
          <tr class="bg-gray-50">
            <td class="border border-gray-300 px-4 py-3">Droits de mutation</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono font-semibold text-secondary-500">{formatEuro(ancien.droitsMutation)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono font-semibold text-green-600">{formatEuro(neuf.droitsMutation)}</td>
          </tr>
          <tr>
            <td class="border border-gray-300 px-4 py-3">Émoluments du notaire (TTC)</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(ancien.emolumentsTTC)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(neuf.emolumentsTTC)}</td>
          </tr>
          <tr class="bg-gray-50">
            <td class="border border-gray-300 px-4 py-3">Contribution sécurité immobilière</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(ancien.securiteImmobiliere)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(neuf.securiteImmobiliere)}</td>
          </tr>
          <tr>
            <td class="border border-gray-300 px-4 py-3">Débours et frais divers</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(ancien.debours)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono">{formatEuro(neuf.debours)}</td>
          </tr>
          <tr class="bg-primary-50 font-bold">
            <td class="border border-gray-300 px-4 py-3">Total frais de notaire</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono text-primary-700">{formatEuro(ancien.totalFrais)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono text-primary-700">{formatEuro(neuf.totalFrais)}</td>
          </tr>
          <tr class="bg-primary-50">
            <td class="border border-gray-300 px-4 py-3 font-bold">Pourcentage effectif</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono font-bold">{formatPercent(ancien.pourcentageEffectif)}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono font-bold">{formatPercent(neuf.pourcentageEffectif)}</td>
          </tr>
          <tr class="bg-accent-50">
            <td class="border border-gray-300 px-4 py-3 font-bold">Coût total de l'acquisition</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono font-bold text-lg">{budgetTotal}</td>
            <td class="border border-gray-300 px-4 py-3 text-right font-mono font-bold text-lg">{budgetTotalNeuf}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Economy callout -->
    <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded-r-lg mb-10">
      <p class="text-lg font-bold text-green-800">
        Économie dans le neuf : {economieNeuf}
      </p>
      <p class="text-sm text-green-700 mt-1">
        En achetant un bien neuf à {label}, vous économisez {economieNeuf} de frais de notaire par rapport à un bien ancien au même prix.
      </p>
    </div>

    <!-- SEO Content -->
    <div class="prose prose-lg max-w-none">
      <h2 class="text-2xl font-bold text-primary-600 mb-6">Acheter un bien immobilier à {label} : ce qu'il faut savoir</h2>

      {isLowBudget && (
        <p>
          Avec un budget de {label}, vous visez un segment de marché accessible qui peut correspondre à un studio ou un petit deux-pièces dans une grande métropole, ou à un bien plus spacieux en zone rurale ou dans une ville moyenne. À ce niveau de prix, les frais de notaire représentent une part significative de votre investissement total : <strong>{formatEuro(ancien.totalFrais)}</strong> dans l'ancien, soit presque {formatPercent(ancien.pourcentageEffectif)} du prix du bien. Il est donc particulièrement important de bien les anticiper dans votre plan de financement.
        </p>
      )}

      {isMidBudget && (
        <p>
          Un budget de {label} correspond au prix moyen d'un achat immobilier en France pour un appartement de taille familiale ou une maison en zone périurbaine. À ce niveau de prix, les frais de notaire dans l'ancien s'élèvent à <strong>{formatEuro(ancien.totalFrais)}</strong>, une somme conséquente qui doit absolument être intégrée dans votre plan de financement. La plupart des banques exigent que l'acquéreur dispose d'un apport personnel couvrant au minimum ces frais.
        </p>
      )}

      {isHighBudget && (
        <p>
          Avec un budget de {label}, vous accédez à un segment immobilier de qualité : grande maison en province, bel appartement dans une métropole régionale, ou bien de standing en périphérie parisienne. Les frais de notaire atteignent <strong>{formatEuro(ancien.totalFrais)}</strong> dans l'ancien - une somme importante qui représente à elle seule le prix d'une voiture neuve. L'option du neuf, avec des frais de seulement {formatEuro(neuf.totalFrais)}, peut constituer un argument de poids dans votre décision.
        </p>
      )}

      {isLuxury && (
        <p>
          Pour un bien à {label}, vous êtes dans le segment du haut de marché immobilier. Les frais de notaire dans l'ancien atteignent <strong>{formatEuro(ancien.totalFrais)}</strong>, un montant considérable. À ce niveau d'investissement, la différence entre ancien et neuf est particulièrement marquée : vous pouvez économiser <strong>{economieNeuf}</strong> en optant pour un bien neuf. C'est pourquoi de nombreux acquéreurs dans cette gamme de prix privilégient les programmes neufs ou la VEFA (vente en l'état futur d'achèvement).
        </p>
      )}

      <h3 class="text-xl font-bold text-primary-700 mt-8 mb-4">Détail des frais dans l'ancien à {label}</h3>

      <p>
        Pour un achat à {label} dans l'<strong>ancien</strong>, les frais de notaire se décomposent ainsi : les <strong>droits de mutation</strong> représentent la part la plus importante avec {formatEuro(ancien.droitsMutation)} (5,81 % du prix). Les <strong>émoluments du notaire</strong> s'élèvent à {formatEuro(ancien.emolumentsTTC)} TTC, calculés selon le barème dégressif réglementé. La <strong>contribution de sécurité immobilière</strong> est de {formatEuro(ancien.securiteImmobiliere)} (0,10 % du prix), et les <strong>débours</strong> sont estimés à {formatEuro(ancien.debours)}.
      </p>

      <p>
        Au total, le coût d'acquisition s'élève à <strong>{budgetTotal}</strong>, frais de notaire inclus. C'est ce montant que vous devez financer, que ce soit par apport personnel, prêt immobilier ou combinaison des deux.
      </p>

      <h3 class="text-xl font-bold text-primary-700 mt-8 mb-4">Détail des frais dans le neuf à {label}</h3>

      <p>
        Pour un achat neuf au même prix de {label}, les droits de mutation ne sont que de {formatEuro(neuf.droitsMutation)} (0,715 %). Les émoluments du notaire restent identiques à {formatEuro(neuf.emolumentsTTC)} TTC (le barème des émoluments ne dépend pas du type de bien). La contribution de sécurité immobilière et les débours sont également les mêmes. Le total des frais de notaire dans le neuf est de <strong>{formatEuro(neuf.totalFrais)}</strong>, soit un coût total d'acquisition de <strong>{budgetTotalNeuf}</strong>.
      </p>

      <h3 class="text-xl font-bold text-primary-700 mt-8 mb-4">Comment financer les frais de notaire ?</h3>

      <p>
        Pour un achat à {label}, les frais de notaire de {formatEuro(ancien.totalFrais)} (ancien) ou {formatEuro(neuf.totalFrais)} (neuf) doivent idéalement être couverts par votre <strong>apport personnel</strong>. La plupart des banques considèrent que l'apport minimum doit couvrir ces frais, car les frais de notaire ne créent pas de valeur patrimoniale et ne peuvent pas servir de garantie au prêt.
      </p>

      <p>
        Certains établissements proposent néanmoins un financement « à 110 % », intégrant les frais de notaire dans le prêt. Cette solution, bien que pratique pour les primo-accédants sans épargne suffisante, entraîne un surcoût en intérêts sur la durée du prêt et peut être assortie de conditions plus strictes (taux plus élevé, garanties supplémentaires).
      </p>

      <h3 class="text-xl font-bold text-primary-700 mt-8 mb-4">Foire aux questions</h3>

      <div class="space-y-6">
        {faqData.map((faq) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <h4 class="font-bold text-primary-700 mb-2">{faq.question}</h4>
            <p class="text-gray-700">{faq.answer}</p>
          </div>
        ))}
      </div>

      <!-- Cross-links -->
      <h3 class="text-xl font-bold text-primary-700 mt-8 mb-4">Frais de notaire pour d'autres montants</h3>

      <div class="flex flex-wrap gap-3 my-6">
        {prixData.filter((p) => p.slug !== slug).map((p) => (
          <a
            href={`/frais-notaire-${p.slug}/`}
            class="inline-block px-4 py-2 bg-primary-50 text-primary-700 rounded-lg hover:bg-primary-100 transition-colors text-sm font-medium no-underline"
          >
            {p.label}
          </a>
        ))}
      </div>

      {(prev || next) && (
        <div class="flex justify-between items-center mt-6 gap-4">
          {prev ? (
            <a
              href={`/frais-notaire-${prev.slug}/`}
              class="flex-1 text-center px-4 py-3 bg-gray-100 text-primary-700 rounded-lg hover:bg-gray-200 transition-colors font-medium no-underline"
            >
              &larr; {prev.label}
            </a>
          ) : <div class="flex-1" />}
          {next ? (
            <a
              href={`/frais-notaire-${next.slug}/`}
              class="flex-1 text-center px-4 py-3 bg-gray-100 text-primary-700 rounded-lg hover:bg-gray-200 transition-colors font-medium no-underline"
            >
              {next.label} &rarr;
            </a>
          ) : <div class="flex-1" />}
        </div>
      )}

      <p class="mt-8">
        <a href="/" class="inline-block bg-primary-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-primary-700 transition-colors no-underline">
          Utiliser le calculateur interactif
        </a>
      </p>

      <h3 class="text-xl font-bold text-primary-700 mt-8 mb-4">Sources</h3>

      <ul>
        <li><a href="https://www.service-public.fr/particuliers/vosdroits/F17759" class="text-primary-600 hover:underline" target="_blank" rel="noopener">Service-public.fr - Frais de notaire lors d'un achat immobilier</a></li>
        <li><a href="https://www.legifrance.gouv.fr/" class="text-primary-600 hover:underline" target="_blank" rel="noopener">Légifrance - Code général des impôts, droits de mutation</a></li>
        <li><a href="https://www.notaires.fr/" class="text-primary-600 hover:underline" target="_blank" rel="noopener">Notaires.fr - Barème des émoluments</a></li>
      </ul>

      <div class="bg-accent-50 border-l-4 border-accent-500 p-4 mt-8 rounded-r-lg">
        <p class="text-sm text-gray-700">
          <strong>Avertissement :</strong> Ce calcul est fourni à titre indicatif sur la base des barèmes 2026. Le montant exact des frais de notaire peut varier en fonction du département (taux de taxe départementale réduit dans certains cas), de la valeur du mobilier éventuellement déduit, et des débours réels. Consultez un notaire pour un calcul définitif.
        </p>
      </div>
    </div>
  </section>
</Layout>
